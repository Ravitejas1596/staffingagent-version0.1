# StaffingAgent Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Database (Aurora PostgreSQL in production, local Docker in dev)
DATABASE_URL=postgresql+asyncpg://app_user:changeme_in_production@localhost:5432/staffingagent
DATABASE_ADMIN_URL=postgresql+asyncpg://postgres:localdev@localhost:5432/staffingagent

# Auth
JWT_SECRET=generate-a-real-secret-here

# AWS (leave AWS_ENDPOINT_URL empty for real AWS; set for LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=staffingagent-uploads
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Anthropic (optional — agents fall back to rule-based if not set)
ANTHROPIC_API_KEY=

# Bullhorn (per-tenant creds are in the database; these are defaults for dev)
BULLHORN_REST_URL=
BULLHORN_BEARER_TOKEN=

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
