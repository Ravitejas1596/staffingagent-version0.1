# StaffingAgent.ai — Environment (copy to .env, do not commit .env)

# ── LLM Providers (Smart Router) ─────────────────────────────────────
# Anthropic is REQUIRED (universal fallback). Gemini and OpenAI are
# optional — the Smart Router skips unavailable providers automatically.
# Platform-level keys; per-tenant usage is tracked for billback.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: enables Gemini Flash for structured matching (97% cheaper)
GOOGLE_AI_API_KEY=

# Optional: enables GPT-4o-mini for structured extraction (95% cheaper)
OPENAI_API_KEY=

# Optional: nBrain (knowledge base) — used via API gateway
NBRAIN_API_URL=
NBRAIN_API_KEY=
NBRAIN_QUERY_PATH=/query
NBRAIN_RESULTS_KEY=results

# Optional: Bullhorn REST API — used via API gateway
BULLHORN_REST_URL=
BULLHORN_CLIENT_ID=
BULLHORN_CLIENT_SECRET=
BULLHORN_TOKEN_URL=
BULLHORN_BEARER_TOKEN=
ATS_RESULTS_KEY=data

# Gateway timeout in seconds
GATEWAY_TIMEOUT_SECONDS=20

# Optional: Tenant for local runs (e.g. default, ghr-demo)
STAFFINGAGENT_TENANT=default

# HubSpot (create private app: Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=245521589
HUBSPOT_FORM_GUID=33eb4c23-f577-486b-bd43-806fe31ddf01

# Resend (email delivery for CEO Daily Brief — resend.com)
RESEND_API_KEY=re_your-key-here
CHRIS_EMAIL=chris.scowden@staffingagent.ai
RESEND_USE_VERIFIED_DOMAIN=false

# Notion (optional — CEO Task Board + Daily Brief archive; see docs/notion-setup-guide.md)
# Leave blank to skip Notion sync; email delivery works without these.
NOTION_API_KEY=ntn_your-integration-secret-here
NOTION_DAILY_BRIEFS_DB_ID=
NOTION_TASKS_DB_ID=

# Security Sprint (Workstream 4): Bullhorn credential encryption key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production this is sourced from AWS Secrets Manager and injected into the ECS task.
# BULLHORN_CREDS_KEK_PREVIOUS is only set during key rotation so MultiFernet can
# decrypt rows still encrypted under the old key.
BULLHORN_CREDS_KEK=
BULLHORN_CREDS_KEK_PREVIOUS=
BULLHORN_CREDS_KEK_VERSION=1

# Security Sprint (Workstream 5): JWT signing secret.
# REQUIRED in production — API refuses to boot if missing or shorter than 32 chars.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Twilio — outbound SMS for Time Anomaly agent (docs/twilio-a2p-onboarding.md)
# Per-tenant Messaging Service SIDs live on the tenants table (migration 048).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DRY_RUN=false
TWILIO_TIMEOUT_SECONDS=20

# Bullhorn Time & Expense (BTE) — service-account credentials for agent writes
# (DNW marking, signed timesheet links). Separate from tenant Bullhorn creds.
BTE_SERVICE_ACCOUNT_USERNAME=
BTE_SERVICE_ACCOUNT_PASSWORD=
BTE_SIGNED_URL_TTL_DAYS=7

# Logging
LOG_LEVEL=INFO
